# Gemini API Key for AI suggestions (primary backend)
GEMINI_API_KEY=AIzaSyCDo8YNeu7Miy1MdiVHsGtTE-16d6ah2fE

# Add your OpenAI API key below to enable OpenAI fallback for AI features.
# Restart the Next.js dev server after editing this file.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
# Optional public env for client usage (if needed).
NEXT_PUBLIC_OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# NextAuth URL used to build OAuth callback URLs. Set this to the exact URL
# (including port) you registered in Google Cloud for the OAuth client.
# Example: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
